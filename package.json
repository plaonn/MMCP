{
  "name": "mmcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check:imap": "npm run build --silent && node dist/check-imap.js",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run --exclude 'dist/**'",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "express": "5.1.0",
    "express-rate-limit": "^8.5.2",
    "imapflow": "1.3.6",
    "mailparser": "3.9.9",
    "zod": "4.1.12"
  },
  "devDependencies": {
    "@types/express": "5.0.5",
    "@types/mailparser": "3.4.6",
    "@types/node": "24.10.1",
    "tsx": "4.20.6",
    "typescript": "6.0.3",
    "vitest": "4.1.8"
  }
}
