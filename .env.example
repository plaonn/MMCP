MMCP_HOST=127.0.0.1
MMCP_PORT=3000
MMCP_PUBLIC_URL=https://your-domain.example/mcp
MMCP_OAUTH_OWNER_PASSWORD=replace-with-a-long-random-password
MMCP_OAUTH_SIGNING_SECRET=replace-with-at-least-32-random-characters
MMCP_POLICY_PATH=~/.config/mmcp/mail-policy.json
MMCP_WORKFLOW_DB_PATH=~/.config/mmcp/workflow.sqlite

IMAP_HOST=imap.naver.com
IMAP_PORT=993
IMAP_SECURE=true
IMAP_USER=your-address@naver.com
IMAP_PASSWORD=your-naver-application-password

MMCP_MAX_EMAIL_BYTES=5242880
